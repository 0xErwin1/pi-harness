{
  "name": "pi-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi coding-agent harness: SDD orchestration, subagent delegation discipline, shell safety guards, and skill discovery. Neutralized framework, no persona layer.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "relink": "bash scripts/link.sh",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.67.6",
    "@mariozechner/pi-tui": "0.67.6",
    "@sinclair/typebox": "0.34.49",
    "@types/node": "25.8.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
