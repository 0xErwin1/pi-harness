{
  "name": "pi-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi coding-agent harness: SDD orchestration, subagent delegation discipline, shell safety guards, and skill discovery. Neutralized framework, no persona layer.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "relink": "bash scripts/link.sh",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@sinclair/typebox": "^0.34.49",
    "croner": "^10.0.1",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@earendil-works/pi-tui": "^0.79.8",
    "typebox": "^1.1.38",
    "@types/node": "25.8.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
